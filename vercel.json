{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "data/**/*.json",
          "index.html",
          "style.css",
          "script.js",
          "admin.html",
          "admin.css",
          "admin.js",
          "assets/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/admin",
      "dest": "/server.js"
    },
    {
      "src": "/admin.html",
      "dest": "/server.js"
    },
    {
      "src": "/admin.css",
      "dest": "/server.js"
    },
    {
      "src": "/admin.js",
      "dest": "/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
